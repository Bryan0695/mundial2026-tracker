# Plantilla de variables de entorno. Copia este archivo a ".env" y rellena.
# NUNCA subas tu .env real a git (ya esta en .gitignore).

# API key de api-football.com (solo si quieres datos en vivo).
# En modo manual no es necesaria.
API_FOOTBALL_KEY=

# Token para proteger las mutaciones (F-001). Si lo dejas vacio, las
# operaciones de escritura NO piden autenticacion (uso local personal).
# Para activarlo: pon aqui un token y el mismo valor en panel.html (ADMIN_TOKEN).
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_TOKEN=

# Origen permitido para CORS (F-006). Por defecto localhost.
FRONTEND_ORIGIN=http://localhost:8000
